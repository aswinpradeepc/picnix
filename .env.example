GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=
GOOGLE_CLOUD_PROJECT=
# Use "global" — gemini-3.1-pro-preview is served on the global endpoint
GOOGLE_CLOUD_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=
# Gemini transient quota/rate-limit retries use capped exponential backoff with jitter.
LLM_RETRY_ATTEMPTS=5
LLM_RETRY_BACKOFF_MIN_SECONDS=1
LLM_RETRY_BACKOFF_MAX_SECONDS=30
# Resend email verification. Set APP_BASE_URL to your public Streamlit URL in deployment.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Picnix <onboarding@resend.dev>"
APP_BASE_URL=http://localhost:8501
# Optional: DEBUG=true exports the graph diagram to docs/ on startup
DEBUG=false

# Observability (Phoenix-first for this milestone; disabled by default)
OBSERVABILITY_ENABLED=false
ARIZE_PRODUCT=phoenix
ARIZE_PROJECT_NAME=picnix-local
# false hides prompts, user inputs, and model outputs from traces; set true only for local debugging
OBSERVABILITY_CAPTURE_CONTENT=false
# For a separately running local Phoenix server, leave this blank; the OTLP collector defaults to localhost:4317
# The local Phoenix dashboard is usually http://127.0.0.1:6006
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=

# PostgreSQL persistence. Docker Compose uses POSTGRES_* for the db container.
POSTGRES_DB=picnix
POSTGRES_USER=picnix
POSTGRES_PASSWORD=picnix
# Local fallback expected by config/settings.py when DATABASE_URL is blank/unset.
DATABASE_URL=postgresql://picnix:picnix@localhost:5432/picnix
# Restricts LangGraph checkpoint deserialization to known-safe modules.
LANGGRAPH_STRICT_MSGPACK=true

# Streamlit authentication cookie. Use a long random value for AUTH_COOKIE_KEY in deployment.
AUTH_COOKIE_NAME=picnix_auth
AUTH_COOKIE_KEY=
AUTH_COOKIE_EXPIRY_DAYS=30

# Phoenix dashboard auth for self-hosted Docker Compose deployments
PHOENIX_ENABLE_AUTH=false
# Required when PHOENIX_ENABLE_AUTH=true. Generate with: openssl rand -hex 32
PHOENIX_SECRET=
# Only used on the first startup that creates the default admin account.
# Login email is admin@localhost.
PHOENIX_DEFAULT_ADMIN_INITIAL_PASSWORD=
PHOENIX_ENABLE_STRONG_PASSWORD_POLICY=true
# Example for public HTTP access: http://<VM_EXTERNAL_IP>:6006
PHOENIX_CSRF_TRUSTED_ORIGINS=
